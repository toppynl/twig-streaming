{
  "name": "toppy/twig-streaming",
  "description": "Streaming template rendering with deferred slots and Early Hints for Twig",
  "type": "library",
  "license": "proprietary",
  "autoload": {
    "psr-4": {
      "Toppy\\TwigStreaming\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Toppy\\TwigStreaming\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.4",
    "toppy/async-view-model": "^0.5",
    "twig/twig": "^3.0",
    "amphp/amp": "^3.0",
    "symfony/http-foundation": "^6.4 || ^7.0 || ^8.0",
    "symfony/service-contracts": "^1.0 || ^2.0 || ^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5",
    "symfony/asset": "^6.4 || ^7.0 || ^8.0",
    "symfony/http-kernel": "^6.4 || ^7.0 || ^8.0"
  }
}
